# =============================================================================
# SOCIAL VIENS — Environment Variables
# =============================================================================
# Copy this file to `.env` (local dev) or set these in your Vercel dashboard
# (Project → Settings → Environment Variables) for production.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. DATABASE  (REQUIRED)
# -----------------------------------------------------------------------------
# Local development — SQLite file
DATABASE_URL="file:./db/custom.db"

# >>> IMPORTANT FOR VERCEL / SERVERLESS PRODUCTION <<<
# SQLite writes to a local file. Vercel's serverless functions have an
# EPHEMERAL filesystem — any SQLite file is wiped between cold starts.
# The public website still renders (it falls back to built-in data),
# but admin changes, captured leads, and chat history will NOT persist.
#
# For production, switch to a hosted Postgres:
#   • Neon          → https://neon.tech       (recommended, free tier)
#   • Supabase      → https://supabase.com    (free tier)
#   • Vercel Postgres → https://vercel.com/docs/storage
#
# After creating your DB, replace the line above with:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
#
# Then update prisma/schema.prisma datasource:
#   datasource db { provider = "postgresql"  url = env("DATABASE_URL") }
# And run:  bun run db:push


# -----------------------------------------------------------------------------
# 2. AI PROVIDER  (OPTIONAL — for the AI chatbot / Analysis Lab)
# -----------------------------------------------------------------------------
# The chatbot works with ONE of the three providers below. If none are set,
# it falls back to a friendly canned-response mode (no API calls).

# Option A — OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY="sk-..."
# Default model: gpt-4o-mini

# Option B — Google Gemini (https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY="AIza..."
# Default model: gemini-1.5-flash

# Option C — Z.AI
# ZAI_API_KEY="..."


# -----------------------------------------------------------------------------
# 3. EMAIL / SMTP  (OPTIONAL — for sending PDF audit reports)
# -----------------------------------------------------------------------------
# If unset, audit tools still generate the report download in-browser,
# but the "email me a copy" feature uses an ephemeral test provider.
#
# Free option: Resend (https://resend.com) — SMTP host: smtp.resend.com
# Or Gmail SMTP: host smtp.gmail.com, port 587, user = your gmail,
# pass = an App-Password (NOT your normal Gmail password).

# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"            # true for port 465, false for 587
# SMTP_USER="resend"
# SMTP_PASS="re_..."
# SMTP_FROM_EMAIL="reports@yourdomain.com"


# -----------------------------------------------------------------------------
# 4. SITE METADATA  (OPTIONAL but recommended for SEO)
# -----------------------------------------------------------------------------
# Used for canonical URLs, sitemap, OpenGraph tags. If unset, falls back
# to "https://socialviens.com". After deploying, set this to your real
# Vercel/domain URL (NO trailing slash).

# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"


# -----------------------------------------------------------------------------
# 5. ADMIN NOTIFICATIONS  (OPTIONAL)
# -----------------------------------------------------------------------------
# Email where new-lead / chat / newsletter notifications are sent.
# If unset, defaults to socialviens@gmail.com.

# ADMIN_EMAIL="founder@yourdomain.com"


# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# • Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# • NEVER commit the real `.env` file to git. Only `.env.example` is tracked.
# • On Vercel, set variables for Production, Preview, and Development separately.
